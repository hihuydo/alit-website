# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (local dev typically points at localhost:5432).
DATABASE_URL=postgresql://alit_user:CHANGE_ME@localhost:5432/alit

# JWT signing secret for the admin dashboard (≥32 random chars).
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Admin bootstrap credentials — used once on first boot to seed the admin user.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2a$12$CHANGE_ME_BCRYPT_HASH

# Absolute public site URL (used by metadataBase, sitemap, canonical tags).
# Per-environment override in docker-compose: prod vs staging.
SITE_URL=https://alit.hihuydo.com

# Salt for sha256 hashing of client IPs on signup (DSGVO minimization).
# Must be ≥16 chars. Changing this invalidates all existing ip_hash values.
IP_HASH_SALT=CHANGE_ME_TO_AT_LEAST_16_RANDOM_CHARS

# Optional bcrypt cost override. Default: 12 (OWASP 2026 Tier-0 minimum).
# Range 4..15 (clamped with warning if outside). Only set <12 for tests or
# emergency rollback.
# BCRYPT_ROUNDS=12
